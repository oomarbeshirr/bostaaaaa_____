{
	"info": {
		"_postman_id": "bosta-tracking-api-collection",
		"name": "Bosta Delivery Tracking API",
		"description": "Collection for testing Bosta delivery tracking API endpoints",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Track Shipment",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"// Assertion 1: Response code is 200",
							"pm.test(\"Status code is 200\", function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"// Assertion 2: Response time is less than 100ms",
							"pm.test(\"Response time is less than 100ms\", function () {",
							"    pm.expect(pm.response.responseTime).to.be.below(100);",
							"});",
							"",
							"// Assertion 3: Response has required fields",
							"pm.test(\"Response has required fields\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData).to.have.property('CurrentStatus');",
							"    pm.expect(jsonData).to.have.property('TrackingNumber');",
							"    pm.expect(jsonData).to.have.property('TrackingURL');",
							"    pm.expect(jsonData).to.have.property('SupportPhoneNumbers');",
							"    pm.expect(jsonData).to.have.property('CreateDate');",
							"    pm.expect(jsonData).to.have.property('TransitEvents');",
							"});",
							"",
							"// Assertion 4: TrackingNumber matches request",
							"pm.test(\"TrackingNumber matches request\", function () {",
							"    var jsonData = pm.response.json();",
							"    var requestedTrackingNumber = pm.environment.get(\"tracking_number\");",
							"    pm.expect(jsonData.TrackingNumber).to.eql(requestedTrackingNumber);",
							"});",
							"",
							"// Assertion 5: CurrentStatus is an object",
							"pm.test(\"CurrentStatus is an object\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData.CurrentStatus).to.be.an('object');",
							"});",
							"",
							"// Assertion 6: TransitEvents is an array",
							"pm.test(\"TransitEvents is an array\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData.TransitEvents).to.be.an('array');",
							"});",
							"",
							"// Assertion 7: SupportPhoneNumbers is an array",
							"pm.test(\"SupportPhoneNumbers is an array\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData.SupportPhoneNumbers).to.be.an('array');",
							"    pm.expect(jsonData.SupportPhoneNumbers.length).to.be.at.least(1);",
							"});",
							"",
							"// Assertion 8: TrackingURL is a valid URL",
							"pm.test(\"TrackingURL is a valid URL\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData.TrackingURL).to.match(/^https?:\\/\\/.+/);",
							"});",
							"",
							"// Assertion 9: Response Content-Type is JSON",
							"pm.test(\"Response Content-Type is JSON\", function () {",
							"    pm.expect(pm.response.headers.get(\"Content-Type\")).to.include(\"application/json\");",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json",
						"type": "text"
					},
					{
						"key": "X-Requested-By",
						"value": "Landmark",
						"type": "text"
					},
					{
						"key": "Accept",
						"value": "application/json",
						"type": "text"
					}
				],
				"url": {
					"raw": "{{base_url}}/shipments/track/{{tracking_number}}",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"shipments",
						"track",
						"{{tracking_number}}"
					]
				},
				"description": "Get the full history of a specific delivery using tracking number"
			},
			"response": []
		},
		{
			"name": "Track Shipment - Invalid Tracking Number",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"// Assertion: Response code is 404 for invalid tracking number",
							"pm.test(\"Status code is 404\", function () {",
							"    pm.response.to.have.status(404);",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json",
						"type": "text"
					},
					{
						"key": "X-Requested-By",
						"value": "Landmark",
						"type": "text"
					},
					{
						"key": "Accept",
						"value": "application/json",
						"type": "text"
					}
				],
				"url": {
					"raw": "{{base_url}}/shipments/track/9999999",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"shipments",
						"track",
						"9999999"
					]
				},
				"description": "Test invalid tracking number - should return 404"
			},
			"response": []
		},
		{
			"name": "Track Shipment - XML Response",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"// Assertion: Response code is 200",
							"pm.test(\"Status code is 200\", function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"// Assertion: Response Content-Type is XML",
							"pm.test(\"Response Content-Type is XML\", function () {",
							"    pm.expect(pm.response.headers.get(\"Content-Type\")).to.include(\"application/xml\");",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "Content-Type",
						"value": "text/xml",
						"type": "text"
					},
					{
						"key": "X-Requested-By",
						"value": "Landmark",
						"type": "text"
					},
					{
						"key": "Accept",
						"value": "application/xml",
						"type": "text"
					}
				],
				"url": {
					"raw": "{{base_url}}/shipments/track/{{tracking_number}}",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"shipments",
						"track",
						"{{tracking_number}}"
					]
				},
				"description": "Test API with XML response format"
			},
			"response": []
		}
	],
	"variable": [
		{
			"key": "base_url",
			"value": "https://tracking.bosta.co",
			"type": "string"
		},
		{
			"key": "tracking_number",
			"value": "6636234",
			"type": "string"
		}
	]
}
